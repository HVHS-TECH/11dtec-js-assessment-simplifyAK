/* Containers */

.container {
    display: grid;
    grid-template-rows: auto auto;
    gap: 20px;
    padding: 20px;
    background-color: #AFD2F1;
}

.secondcontainer {
    display:grid;
    
}

.gallerycontainer {
    display:grid;
    grid-template-columns: 2/3fr 1/3fr;
    background-color: #fffdd0;
}

.navbar {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    padding: 20px;
    background-color: #AFD2F1;
}



/* Dropdown Stuff + some extra navbar stuff*/

.dropdown {
    position: relative;
    display: flex;
    justify-content: center;
    
    background-color: #AFD2F1;
}

.dropbtn {
    background-color: #AFD2F1;
    color: black;
    font-size: 20px;
    padding: 10px 20px;
    border: none;
    cursor: pointer;
    border-radius: 5px;
}

.dropdown-content {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background-color: white;
    min-width: 150px;
    border: 1px solid #ccc;
    border-radius: 5px;
}

.dropdown-content a {
    display: block;
    padding: 12px;
    text-decoration: none;
    color: black;
    text-align: center;
}

.dropdown-content a:hover {
    background-color: #AFD2F1;
}

.dropdown:hover .dropdown-content {
    display: block;
}

.dropdown:hover .dropbtn {
    background-color: #9EC8EC;
}

.cartnavbar {
    position: absolute;
    top: 20px;
    right: 20px;
}

